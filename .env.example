# =============================================================================
# .env.example — AI Academic Assistant
# SAFE TO COMMIT: placeholder values only — no real secrets.
#
# Setup instructions:
#   1. Copy this file:  cp .env.example .env
#   2. Replace each value with your real API key
#   3. NEVER commit .env — it is in .gitignore
#
# For Streamlit Community Cloud:
#   Add these keys under App Settings → Secrets (TOML format):
#   [secrets]
#   GROQ_API_KEY = "your_key_here"
#   GOOGLE_API_KEY = "your_key_here"
# =============================================================================

# Groq API Key — free at https://console.groq.com/
GROQ_API_KEY=your_groq_api_key_here

# Google API Key — reserved for future Google AI features
GOOGLE_API_KEY=your_google_api_key_here
